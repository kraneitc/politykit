@inject ICharterfallSessionStore SessionStore
@inject IPrototypeContentProvider ContentProvider
@inject IPolityKitRunClient RunClient
@inject IPlayerMessageFormatter Messages
@inject NavigationManager Navigation

<section class="prototype-shell">
    <header class="shell-header">
        <div>
            <p class="eyebrow">Chapter @ActiveCrisis.ChapterNumber of @CampaignCrises.Count / @ActiveCrisis.DisplayName</p>
            <h1>@StageTitle</h1>
            <p>@StageSummary</p>
        </div>
        <div class="run-state">
            <span>@ActiveCrisis.IntegrationStatus</span>
            <strong>@(Session.IsBusy ? "Resolving" : "Ready")</strong>
        </div>
    </header>

    <div class="shell-grid">
        <main class="state-panel" aria-live="polite">
            <div class="panel-heading">
                <span>@Content.Settlement.Name</span>
                <strong>@ActiveCrisis.DisplayName</strong>
            </div>

            @switch (Stage)
            {
                case CharterfallStage.Draft:
                    <section>
                        <h2>Draft civic response</h2>
                        <p>@Content.Settlement.Premise</p>
                        <div class="active-crisis">
                            <span>Active crisis</span>
                            <strong>Chapter @ActiveCrisis.ChapterNumber: @ActiveCrisis.DisplayName</strong>
                            <p>@ActiveCrisis.Summary</p>
                            <small>This crisis will be tested under the listed scenario, seed, and tick assumptions.</small>
                        </div>
                        <div class="scenario-list">
                            @if (CampaignCrises.Count == 0)
                            {
                                <p class="empty-state">No crisis cards are configured for this campaign.</p>
                            }
                            else
                            {
                                @foreach (var crisis in CampaignCrises)
                                {
                                    var isActive = crisis.Id == Session.ActiveCrisisId;
                                    <button type="button"
                                            class="scenario-card @(isActive ? "active" : string.Empty)"
                                            disabled="@(!crisis.IsUnlocked)"
                                            @onclick="() => SelectCrisis(crisis)">
                                        <span>Chapter @crisis.ChapterNumber</span>
                                        <strong>@crisis.DisplayName</strong>
                                        <small>@crisis.DesignPurpose</small>
                                        <em>@crisis.PolityKitScenario</em>
                                        <small>Seed @crisis.Seed, @crisis.Ticks ticks</small>
                                        <small>@string.Join(", ", crisis.StressedClauseDimensions)</small>
                                        <b>@(crisis.IsUnlocked ? crisis.IntegrationStatus : "Locked until campaign advances")</b>
                                    </button>
                                }
                            }
                        </div>
                        <section class="charter-draft">
                            <div class="section-heading">
                                <h2>Charter clauses</h2>
                                <p>Choose one simulation-active allocation method. Other first-pass clauses stay visible as preset-backed or presentation-only Charterfall state.</p>
                            </div>
                            @foreach (var dimension in ClauseDimensions)
                            {
                                var clauses = ContentProvider.GetClausesForDimension(dimension.Key);
                                <div class="clause-group">
                                    <div>
                                        <h3>@dimension.Value</h3>
                                        @if (dimension.Key == "allocation_method")
                                        {
                                            <small>Required simulation-active choice</small>
                                        }
                                        else
                                        {
                                            <small>Stored for presentation, preset explanation, or later composition</small>
                                        }
                                    </div>
                                    <div class="clause-list">
                                        @foreach (var clause in clauses)
                                        {
                                            var isSelected = Session.SelectedClauseIds.Contains(clause.Id);
                                            <button type="button"
                                                    class="clause-card @(isSelected ? "selected" : string.Empty)"
                                                    @onclick="() => SelectClause(clause)">
                                                <span>@MappingStatusLabel(clause)</span>
                                                <strong>@clause.DisplayName</strong>
                                                <small>@clause.Description</small>
                                                <em>@clause.Tradeoff</em>
                                                <b>@clause.Boundary</b>
                                                @if (clause.MappingStatus == "game-layer-only")
                                                {
                                                    <small>This clause affects Charterfall presentation and campaign notes in this prototype. It is not yet a PolityKit simulation input.</small>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                            @if (ClauseValidation.Errors.Count > 0)
                            {
                                <div class="error-state clause-errors">
                                    @foreach (var error in ClauseValidation.Errors)
                                    {
                                        <p>@error</p>
                                    }
                                </div>
                            }
                            <div class="run-preview">
                                <div>
                                    <span>Selected charter</span>
                                    <strong>@SelectedClauseSummary</strong>
                                </div>
                                <div>
                                    <span>Run input preview</span>
                                    <pre>@DraftRunRequestJson</pre>
                                </div>
                            </div>
                            <details class="debug-request">
                                <summary>Developer request preview</summary>
                                <pre>@DraftRunRequestJson</pre>
                            </details>
                        </section>
                    </section>
                    break;
                case CharterfallStage.Inquiry:
                    <section>
                        <h2>Public inquiry dashboard</h2>
                        <p>@InquiryCopy</p>
                        <div class="metric-grid">
                            @foreach (var metric in Content.Metrics)
                            {
                                <div class="metric-card">
                                    <span>@metric.Name</span>
                                    <strong>Pending</strong>
                                </div>
                            }
                        </div>
                    </section>
                    break;
                case CharterfallStage.Amendment:
                    <section>
                        <h2>Amend charter</h2>
                        <p>Adjust the selected clause set after inquiry. This prototype keeps the same @ActiveCrisis.DisplayName assumptions visible for a later same-seed rerun.</p>
                        <div class="draft-summary">
                            <span>Selected clauses</span>
                            <strong>@SelectedClauseSummary</strong>
                        </div>
                    </section>
                    break;
                case CharterfallStage.Comparison:
                    <section>
                        <h2>Compare runs</h2>
                        <p>Original and amended outcomes will appear here once rerun and comparison endpoints are wired. Placeholder records remain visibly separate from authoritative PolityKit data.</p>
                        <div class="comparison-strip">
                            <div>
                                <span>Original</span>
                                <strong>@RunLabel("Original")</strong>
                            </div>
                            <div>
                                <span>Amended</span>
                                <strong>@RunLabel("Amended")</strong>
                            </div>
                        </div>
                    </section>
                    break;
                case CharterfallStage.Outcome:
                    <section>
                        <h2>Final outcome</h2>
                        <p>Greywater Compact reaches a provisional chapter outcome. Campaign advance, chapter 2, and chapter 3 carryover remain pending future slices.</p>
                        <div class="draft-summary">
                            <span>Continuation run</span>
                            <strong>@(Session.SelectedContinuationRunId ?? "Not selected")</strong>
                        </div>
                    </section>
                    break;
            }

            <div class="action-bar">
                @if (BackTarget is not null)
                {
                    <button type="button" class="secondary-action" @onclick="GoBack">Back</button>
                }
                <button type="button" class="primary-action" @onclick="PrimaryActionAsync" disabled="@PrimaryActionDisabled">@PrimaryActionText</button>
            </div>
        </main>

        <aside class="support-column">
            <section class="support-panel">
                <h2>Assumptions</h2>
                <dl>
                    <div><dt>Settlement</dt><dd>@Content.Settlement.Name</dd></div>
                    <div><dt>Crisis</dt><dd>@ActiveCrisis.DisplayName</dd></div>
                    <div><dt>Scenario</dt><dd>@ActiveCrisis.PolityKitScenario</dd></div>
                    <div><dt>Seed</dt><dd>@ActiveCrisis.Seed</dd></div>
                    <div><dt>Ticks</dt><dd>@ActiveCrisis.Ticks</dd></div>
                    <div><dt>Chapter</dt><dd>@ActiveCrisis.ChapterNumber of @CampaignCrises.Count</dd></div>
                    <div><dt>Charter</dt><dd>@SelectedClauseSummary</dd></div>
                </dl>
                @if (!ActiveCrisis.IsIntegrationAvailable)
                {
                    <p class="empty-state">Integration pending: this crisis card is available for campaign planning, but run creation is not wired for this scenario yet.</p>
                }
                <p class="boundary">@Content.ClaimsBoundary</p>
            </section>

            <section class="support-panel">
                <h2>Run history</h2>
                @if (Session.RunHistory.Count == 0)
                {
                    <p class="empty-state">No runs have been created yet. Resolve the draft to create the first placeholder record.</p>
                }
                else
                {
                    <ol class="run-list">
                        @foreach (var run in Session.RunHistory)
                        {
                            <li>
                                <strong>@run.Label</strong>
                                <span>@run.RunId</span>
                                <small>@run.Status</small>
                            </li>
                        }
                    </ol>
                }
            </section>

            <section class="status-panel">
                <h2>Status</h2>
                @if (Session.IsBusy)
                {
                    <p class="loading-state">@ResolvingStatusText</p>
                }
                @if (ResolveBlockingMessage is not null)
                {
                    <p class="empty-state">@ResolveBlockingMessage</p>
                }
                @if (Session.LastError is not null)
                {
                    <p class="error-state">@Session.LastError</p>
                }
                <p class="pending-state">@Messages.IntegrationPending()</p>
            </section>
        </aside>
    </div>
</section>

@code {
    [Parameter]
    public CharterfallStage Stage { get; set; }

    private CharterfallSession Session => SessionStore.Current;

    private PrototypeContent Content => ContentProvider.GetInitialContent();

    private IReadOnlyList<CrisisCard> CampaignCrises => ContentProvider.GetCampaignCrises();

    private IReadOnlyDictionary<string, string> ClauseDimensions { get; } = new Dictionary<string, string>
    {
        ["allocation_method"] = "Allocation method",
        ["transparency"] = "Transparency",
        ["accountability"] = "Accountability",
        ["emergency_powers"] = "Emergency powers"
    };

    private CrisisCard ActiveCrisis =>
        ContentProvider.FindCrisis(Session.ActiveCrisisId)
        ?? ContentProvider.GetActiveCrisis(Session.ChapterNumber);

    private CharterRunInputPreview ClausePreview =>
        ContentProvider.BuildRunInputPreview(Session.SelectedClauseIds);

    private ClauseSelectionValidationResult ClauseValidation =>
        ContentProvider.ValidateClauseSelection(Session.SelectedClauseIds);

    private CreateRunInput DraftRunRequest =>
        new(
            ActiveCrisis.PolityKitScenario,
            ActiveCrisis.Seed,
            ActiveCrisis.Ticks,
            ClausePreview.Models,
            ClausePreview.Parameters);

    private string StageTitle => Stage switch
    {
        CharterfallStage.Draft => "Draft",
        CharterfallStage.Inquiry => "Inquiry",
        CharterfallStage.Amendment => "Amendment",
        CharterfallStage.Comparison => "Comparison",
        CharterfallStage.Outcome => "Final Outcome",
        _ => "Draft"
    };

    private string StageSummary => Stage switch
    {
        CharterfallStage.Draft => $"Choose the first charter posture for Greywater Compact before resolving {ActiveCrisis.DisplayName}.",
        CharterfallStage.Inquiry => "Review where dashboard metrics, event timelines, and bounded conclusions will appear.",
        CharterfallStage.Amendment => "Prepare a same-seed charter adjustment after the inquiry.",
        CharterfallStage.Comparison => "Compare original and amended records while keeping placeholder state explicit.",
        CharterfallStage.Outcome => "Choose what carries forward once chapter progression exists.",
        _ => string.Empty
    };

    private string InquiryCopy => Session.AuthoritativeRunIds.Count == 0
        ? "Empty inquiry: no dashboard response exists yet."
        : "Dashboard metrics are reserved for deterministic PolityKit output. The values below are placeholders.";

    private string SelectedClauseSummary => Session.SelectedClauseIds.Count == 0
        ? "No player-facing clauses selected"
        : string.Join(", ", Session.SelectedClauseIds
            .Select(ContentProvider.FindClause)
            .OfType<CharterClauseDefinition>()
            .Select(clause => clause.DisplayName));

    private string DraftRunRequestJson =>
        System.Text.Json.JsonSerializer.Serialize(DraftRunRequest, new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)
        {
            WriteIndented = true
        });

    private string PrimaryActionText => Stage switch
    {
        CharterfallStage.Draft => Session.IsResolvingRun ? "Resolving Crisis" : "Resolve Crisis",
        CharterfallStage.Inquiry => "Open Amendment",
        CharterfallStage.Amendment => "Create Amended Placeholder",
        CharterfallStage.Comparison => "Accept Current Run",
        CharterfallStage.Outcome => "Restart Draft",
        _ => "Continue"
    };

    private bool PrimaryActionDisabled =>
        Session.IsBusy || (Stage == CharterfallStage.Draft && ResolveBlockingMessage is not null);

    private string ResolvingStatusText => Session.IsResolvingRun
        ? $"Submitting {ActiveCrisis.PolityKitScenario} with {string.Join(", ", ClausePreview.Models)}..."
        : "Resolving state...";

    private string? ResolveBlockingMessage
    {
        get
        {
            if (Stage != CharterfallStage.Draft)
            {
                return null;
            }

            if (!ActiveCrisis.IsIntegrationAvailable)
            {
                return $"{ActiveCrisis.DisplayName} is part of the campaign, but run creation is not wired for this scenario yet.";
            }

            if (!ClauseValidation.IsValid)
            {
                return string.Join(" ", ClauseValidation.Errors);
            }

            if (ClausePreview.Models.Count == 0)
            {
                return "Choose a simulation-active charter clause before resolving the crisis.";
            }

            return null;
        }
    }

    private string? BackTarget => Stage switch
    {
        CharterfallStage.Draft => null,
        CharterfallStage.Inquiry => "draft",
        CharterfallStage.Amendment => "inquiry",
        CharterfallStage.Comparison => "amend",
        CharterfallStage.Outcome => "compare",
        _ => null
    };

    protected override void OnParametersSet()
    {
        SessionStore.ClearError();

        if (Stage == CharterfallStage.Inquiry)
        {
            Session.HasViewedInquiry = true;
            if (Session.RunHistory.Count == 0)
            {
                SessionStore.SetError(Messages.MissingRunForInquiry());
            }
        }

        if (Stage == CharterfallStage.Comparison && Session.RunHistory.Count(run => run.Label == "Amended") == 0)
        {
            SessionStore.SetError(Messages.MissingAmendedRunForComparison());
        }

        if (ContentProvider.FindCrisis(Session.ActiveCrisisId) is null)
        {
            SessionStore.SetError($"The active chapter has no matching Charterfall crisis card: {Session.ActiveCrisisId}.");
        }
    }

    private void SelectCrisis(CrisisCard crisis)
    {
        if (!crisis.IsUnlocked)
        {
            SessionStore.SetError($"{crisis.DisplayName} is locked until the campaign advances to chapter {crisis.ChapterNumber}.");
            return;
        }

        if (string.IsNullOrWhiteSpace(crisis.PolityKitScenario))
        {
            SessionStore.SetError($"{crisis.DisplayName} has no PolityKit scenario source configured.");
            return;
        }

        SessionStore.SelectCrisis(crisis);

        if (!crisis.IsIntegrationAvailable)
        {
            SessionStore.SetError($"{crisis.DisplayName} is part of the campaign, but its PolityKit scenario source is not executable through the current prototype path yet.");
        }
    }

    private void SelectClause(CharterClauseDefinition clause)
    {
        var selected = Session.SelectedClauseIds.ToList();
        if (clause.Dimension == "allocation_method")
        {
            selected.RemoveAll(id => ContentProvider.FindClause(id)?.Dimension == "allocation_method");
            selected.Add(clause.Id);
        }
        else if (selected.Contains(clause.Id))
        {
            selected.Remove(clause.Id);
        }
        else
        {
            selected.RemoveAll(id => ContentProvider.FindClause(id)?.Dimension == clause.Dimension);
            selected.Add(clause.Id);
        }

        SyncClauseSelection(selected);
    }

    private void SyncClauseSelection(IReadOnlyList<string>? selectedClauseIds = null)
    {
        var selected = (selectedClauseIds ?? Session.SelectedClauseIds).ToArray();
        var preview = ContentProvider.BuildRunInputPreview(selected);
        var validation = ContentProvider.ValidateClauseSelection(selected);
        var selectedClauses = selected
            .Select(ContentProvider.FindClause)
            .OfType<CharterClauseDefinition>()
            .ToArray();

        SessionStore.UpdateClauseSelection(selected, preview, validation, selectedClauses);
    }

    private static string MappingStatusLabel(CharterClauseDefinition clause) => clause.MappingStatus switch
    {
        "run-model" => "Simulation-active",
        "preset-dimension" => "Preset-backed explanation",
        "game-layer-only" => "Presentation-only",
        _ => clause.MappingStatus
    };

    private async Task PrimaryActionAsync()
    {
        SessionStore.ClearError();

        switch (Stage)
        {
            case CharterfallStage.Draft:
                SyncClauseSelection();
                if (ResolveBlockingMessage is not null)
                {
                    SessionStore.SetError(ResolveBlockingMessage);
                    return;
                }
                await CreateRunAsync("Original");
                break;
            case CharterfallStage.Inquiry:
                Session.HasViewedInquiry = true;
                Navigation.NavigateTo("amend");
                break;
            case CharterfallStage.Amendment:
                AddLocalPendingRun("Amended");
                Navigation.NavigateTo("compare");
                break;
            case CharterfallStage.Comparison:
                Session.SelectedContinuationRunId = Session.RunHistory.LastOrDefault()?.RunId;
                Navigation.NavigateTo("outcome");
                break;
            case CharterfallStage.Outcome:
                Navigation.NavigateTo("draft");
                break;
        }
    }

    private async Task CreateRunAsync(string label)
    {
        var request = DraftRunRequest;
        var requestJson = DraftRunRequestJson;
        SessionStore.BeginRunResolution(request, requestJson);

        var result = await RunClient.CreateRunAsync(request);
        if (!result.IsSuccess || result.Id is null)
        {
            SessionStore.FailRunResolution(request, result.RawRequest, result.ErrorMessage ?? "PolityKit run creation failed.");
            return;
        }

        var run = new PrototypeRunRecord(
            result.Id.Value.ToString(),
            label,
            result.ScenarioName,
            result.Seed,
            result.Ticks,
            IsAuthoritative: true,
            $"Created by PolityKit at {result.CreatedAt:yyyy-MM-dd HH:mm:ss zzz}");

        SessionStore.CompleteRunResolution(request, result, run);
        Session.CompactInquirySummary = "Run created. Dashboard inquiry integration is pending the next slice.";
        Navigation.NavigateTo("inquiry");
    }

    private void AddLocalPendingRun(string label)
    {
        var slug = label.ToLowerInvariant().Replace(' ', '-');
        var run = new PrototypeRunRecord(
            $"pending-{slug}-run",
            label,
            ActiveCrisis.PolityKitScenario,
            ActiveCrisis.Seed,
            ActiveCrisis.Ticks,
            IsAuthoritative: false,
            "Integration pending: amendment rerun is not wired yet");

        Session.RunHistory.RemoveAll(existing => existing.Label == label);
        Session.RunHistory.Add(run);
    }

    private void GoBack()
    {
        if (BackTarget is not null)
        {
            Navigation.NavigateTo(BackTarget);
        }
    }

    private string RunLabel(string label) =>
        Session.RunHistory.FirstOrDefault(run => run.Label == label)?.RunId ?? "Pending";
}
